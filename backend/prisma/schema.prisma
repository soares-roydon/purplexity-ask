generator client {
	provider = "prisma-client"
	output = "./generated"
	engineType = "client"
	runtime = "bun"
}

datasource db {
	provider = "postgresql"
}

// Defining the schema

model User {
  id              String           @id           @default(uuid())
  email           String
  provider        AuthProvider
  name            String
  supabaseId      String
  conversations   Conversation[]
}

model Conversation {
  id           String           @id           @default(uuid())
  title        String
  slug         String
  userId       String
  messages     Message[]
  user         User             @relation(fields: [userId], references: [id])
}

model Message {
  id                Int              @id                  @default(autoincrement())
  content           String
  role              MessageRole
  conversationId    String
  conversation      Conversation     @relation(fields: [conversationId], references: [id])
  createdAt         DateTime         @default(now())
}

enum MessageRole{
  User
  Assistant
}

enum AuthProvider {
  GutHub
  Google
}